{
  "expo": {
    "name": "RentAHouse",
    "slug": "Rent-A-House",
    "version": "3.10",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rentahouse",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },

    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSUserNotificationUsageDescription": "We'll notify you when someone messages you or your listing is updated."
      }
    },

    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "backgroundImage": "./assets/images/adaptive-icon.png"
      },
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ],
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.RentAHouse"
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/adaptive-icon.png"
    },

    "plugins": [
      "expo-router",

      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/splash.png",
          "imageWidth": 450,
          "resizeMode": "contain"
        }
      ],

      "expo-web-browser",
      "expo-localization",

      [
        "expo-notifications",
        {
          "icon": "./assets/images/adaptive-icon.png",
          "color": "#ffffff",
          "iosDisplayInForeground": true
        }
      ],

      "expo-font",

      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "ndkVersion": "27.1.12297006",
            "packagingOptions": {
              "jniLibs": {
                "useLegacyPackaging": false
              }
            }
          }
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "b5f1e9d5-5e73-4bdb-8540-147020f287ba"
      }
    },

    "owner": "yungbrat"
  }
}